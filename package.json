{
  "name": "openclaw-installer",
  "version": "0.1.0",
  "description": "OpenClaw 中文一键安装助手，提供可复用的 CLI 核心模块。",
  "main": "src/index.js",
  "bin": {
    "openclaw-installer": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "roles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "doctor": "node bin/cli.js doctor",
    "install:openclaw": "node bin/cli.js install",
    "test": "node --test",
    "gui": "electron src/gui/main.js",
    "pack:mac": "electron-builder --mac --dir",
    "dist:mac": "electron-builder --mac dmg"
  },
  "keywords": [
    "openclaw",
    "installer",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.haihuiduan.openclawtoolbox",
    "productName": "OpenClaw 工具箱",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "roles/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/gui/main.js"
    },
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
